rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /challengeAttempts/{attemptId} {
      allow read: if false;
      allow create: if isValidAttempt(request.resource.data);
      allow update, delete: if false;
    }
  }
}

function isValidAttempt(data) {
  return data.keys().hasOnly(["challengeId", "submission", "createdAt"]) &&
    data.challengeId is string &&
    data.submission is string &&
    (
      (data.challengeId == "level1" && data.submission.matches("(?s).*\\[count\\].*")) ||
      (data.challengeId == "level2" && data.submission in ["a", "b", "c"]) ||
      (data.challengeId == "level3" && data.submission in ["a", "b", "c"]) ||
      (data.challengeId == "level4" && data.submission in ["a", "b"])
    );
}
